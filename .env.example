# Copie para .env e preencha os valores
# Em produção, configure as variáveis diretamente no Dokploy

PORT=4000
NODE_ENV=production

# PostgreSQL — use a connection string do serviço Dokploy
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tardoria

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_string_aleatoria_longa

# Configurações do jogo
TICK_RATE=20
MAX_PLAYERS_PER_ROOM=10
